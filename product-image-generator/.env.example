# Copia este archivo como .env y rellena los valores

# API key de Google AI Studio (gratis, sin tarjeta)
# Obtener en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_aqui

# Descripción detallada de tu producto (color, material, logo, forma)
# Ejemplo: "Termo de acero inoxidable 500ml color negro mate con logo blanco"
PRODUCT_DESCRIPTION=describe tu producto aqui

# Carpeta donde se guardan las imágenes generadas
OUTPUT_DIR=output

# Máximo de requests simultáneos (no subir de 5 en free tier)
MAX_CONCURRENT=5

# Archivo CSV con las variaciones (puedes cambiarlo)
VARIATIONS_FILE=variaciones.csv
